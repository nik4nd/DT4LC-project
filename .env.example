# DT4LC Environment Configuration
# Copy this to .env and fill in values

# =============================================================================
# LLM Provider Selection
# =============================================================================
# Enable/disable specific providers (true/false)
LLM_ENABLE_GEMINI=true
LLM_ENABLE_GROQ=true
LLM_ENABLE_OLLAMA=true
LLM_ENABLE_APERTUS=false
LLM_ENABLE_ANTHROPIC=true
LLM_ENABLE_MISTRAL=true

# Provider priority order (comma-separated)
# Available: gemini, groq, ollama, apertus, anthropic, mistral
# System tries providers in this order, falling back on failure.
# Commercial providers (anthropic, mistral) activate only when both their
# API key is set AND they are listed here. Add them like:
#   LLM_PROVIDER_ORDER=anthropic,mistral,gemini,groq,ollama
LLM_PROVIDER_ORDER=gemini,groq,ollama

# Routing strategy: fallback | cost | availability
# - fallback: Try in priority order, fall back on failure (default)
# - cost: Route to cheapest provider
# - availability: Route to first available
LLM_STRATEGY=fallback

# =============================================================================
# LLM API Keys (Optional - system falls back to Ollama if not set)
# =============================================================================

# Google Gemini (fast, free tier with limits)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model selection (comma-separated for rotation)
# Available: gemini-2.0-flash, gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash-lite
# Single model: GEMINI_MODELS=gemini-2.0-flash
# Multiple models (rotates on each request): GEMINI_MODELS=gemini-2.0-flash,gemini-2.5-flash
GEMINI_MODELS=gemini-2.5-flash

# Groq (ultra-fast 300+ tokens/sec, free tier)
# Get key: https://console.groq.com/
GROQ_API_KEY=

# Groq model (single model - already ultra-fast, no rotation needed)
# Available: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# =============================================================================
# Ollama Configuration
# =============================================================================
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# Apertus Configuration (Swiss AI - Local HuggingFace Model)
# =============================================================================
# Apertus is disabled by default (requires GPU with significant VRAM)
# Enable only if you have the hardware:
# - 8B model: ~16GB VRAM
# - 70B model: ~140GB VRAM
APERTUS_ENABLED=false

# Model selection
# Available: swiss-ai/Apertus-8B, swiss-ai/Apertus-70B
APERTUS_MODEL=swiss-ai/Apertus-8B

# GPU device (0, 1, etc.) or "cpu" for CPU inference
APERTUS_DEVICE=0

# Data type: bfloat16 (default), float16, float32
APERTUS_DTYPE=bfloat16

# =============================================================================
# Anthropic Claude Configuration (Optional - commercial, BYO key)
# =============================================================================
# Get key: https://console.anthropic.com/
# Default is Sonnet 4.6 (good balance for orchestration). Override for
# different cost/capability trade-offs:
#   ANTHROPIC_MODELS=claude-opus-4-7    ($5/$25 per Mtok — most capable)
#   ANTHROPIC_MODELS=claude-haiku-4-5   ($1/$5 per Mtok — cheapest)
ANTHROPIC_API_KEY=

# Model selection (comma-separated for rotation across the same provider)
# Known IDs: claude-opus-4-7, claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5
ANTHROPIC_MODELS=claude-sonnet-4-6

# =============================================================================
# Mistral AI Configuration (Optional - commercial, BYO key)
# =============================================================================
# Get key: https://console.mistral.ai/
# Mistral's API is OpenAI-compatible. Not to be confused with Groq's
# `mixtral-*` model family — that's a different company hosting Mistral's
# open-weight models.
MISTRAL_API_KEY=

# Model selection (comma-separated for rotation)
# Known IDs: mistral-large-latest, mistral-medium-latest, mistral-small-latest,
#            ministral-8b-latest, ministral-3b-latest, codestral-latest
MISTRAL_MODELS=mistral-medium-latest

# =============================================================================
# Google Earth Engine Configuration (Optional - for Sentinel-2 data fetching)
# =============================================================================
# Google Cloud Project ID with Earth Engine enabled
# Get started: https://developers.google.com/earth-engine/guides/python_install
# 1. Create a Google Cloud project
# 2. Enable Earth Engine API
# 3. Set up authentication (service account or gcloud)
GEE_PROJECT_ID=

# Optional: Service account key file path for GEE authentication
# If not set, will use default gcloud credentials
GEE_SERVICE_ACCOUNT_KEY=

# =============================================================================
# Server Configuration
# =============================================================================
# Backend port (default: 8000)
BACKEND_PORT=8000

# Frontend port (default: 80)
FRONTEND_PORT=80
